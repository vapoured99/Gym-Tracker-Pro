{
  "entities": {
    "WorkoutPlan": {
      "title": "Workout Plan",
      "description": "The current 4-day workout plan for a user.",
      "type": "object",
      "properties": {
        "days": {
          "type": "array",
          "description": "A 2D array of exercises representing a 4-day cycle."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["days"]
    },
    "PersonalBest": {
      "title": "Personal Best",
      "description": "The best and latest performance for a specific exercise.",
      "type": "object",
      "properties": {
        "bestWeight": { "type": "number" },
        "bestReps": { "type": "number" },
        "bestDate": { "type": "string" },
        "lastWeight": { "type": "number" },
        "lastReps": { "type": "number" },
        "lastDate": { "type": "string" },
        "exerciseName": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bestWeight", "bestReps", "exerciseName"]
    },
    "WeightEntry": {
      "title": "Weight Entry",
      "description": "Body weight tracking entry.",
      "type": "object",
      "properties": {
        "weight": { "type": "number" },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["weight", "date"]
    },
    "SessionSet": {
      "title": "Session Set",
      "description": "A single set performed during a workout session.",
      "type": "object",
      "properties": {
        "exerciseName": { "type": "string" },
        "weight": { "type": "number" },
        "reps": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "description": "YYYY-MM-DD format for grouping" }
      },
      "required": ["exerciseName", "weight", "reps", "date"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "General settings and state for the user.",
      "type": "object",
      "properties": {
        "activeWeek": { "type": "number" },
        "activeView": { "type": "string" },
        "email": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}/workout/current": {
      "schema": "WorkoutPlan",
      "description": "The current active workout plan for the user."
    },
    "/users/{userId}/pbs/{exerciseName}": {
      "schema": "PersonalBest",
      "description": "Tracking progress for individual exercises."
    },
    "/users/{userId}/weightEntries/{entryId}": {
      "schema": "WeightEntry",
      "description": "Body weight history."
    },
    "/users/{userId}/sets/{setId}": {
      "schema": "SessionSet",
      "description": "Log of every set performed."
    },
    "/users/{userId}/profile/settings": {
      "schema": "UserProfile",
      "description": "User specific settings and metadata."
    }
  }
}
